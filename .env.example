# ─────────────────────────────────────────────────────────────────────────────
# Gumbel-MCTS-CLI Environment Variables
# Copy this file to .env and edit as needed.
# All variables have sensible defaults — none are required for basic usage.
# ─────────────────────────────────────────────────────────────────────────────

# ── MCTS Search Parameters ────────────────────────────────────────────────────

# Number of MCTS simulations per search call (higher = better quality, slower)
MCTS_N_SIM=200

# UCB exploration constant for Vanilla MCTS (√2 ≈ 1.414 is canonical)
MCTS_C_PUCT=1.414

# Max depth of random rollouts during leaf evaluation
ROLLOUT_DEPTH=50

# Discount factor for rollout rewards (GridWorld env)
ROLLOUT_GAMMA=0.99

# ── Gumbel-MCTS Specific ──────────────────────────────────────────────────────

# Initial number of actions considered in Gumbel top-k (must be power of 2)
GUMBEL_K=16

# Scale factor for completed-Q interpolation
GUMBEL_C_SCALE=0.5

# ── Benchmark Settings ────────────────────────────────────────────────────────

# Environment to benchmark: "maxtree", "gridworld", or "sequence"
BENCH_ENV=maxtree

# Number of trials to average over
BENCH_N_TRIALS=20

# Global random seed for reproducibility
BENCH_SEED=42

# Speedup ≥ TARGET_SPEEDUP is considered a pass (informational only)
TARGET_SPEEDUP=3.0

# Output format for benchmark_mcts.py: text | json | csv
OUTPUT_FORMAT=text

# Set to 1/true/yes to use minimal budget (5 trials, 40 sims) — for CI
DRY_RUN=false

# ── GridWorld Environment ─────────────────────────────────────────────────────

# NxN grid size
GRID_SIZE=8

# Maximum steps per episode before truncation
MAX_STEPS=200

# ── MaxTree Environment ───────────────────────────────────────────────────────

# Depth of the synthetic game tree
TREE_DEPTH=6

# Number of children per node (branching factor)
TREE_BRANCHING=8

# ── SequenceEnv (combinatorial sequence optimization) ─────────────────────────

# Vocabulary size (branching factor per step)
SEQ_VOCAB_SIZE=8

# Target sequence length (episode depth)
SEQ_DEPTH=5

# ── Tree Visualization ────────────────────────────────────────────────────────

# Maximum tree depth to render in ASCII visualization
VIZ_MAX_DEPTH=3

# Maximum children to show per node in ASCII visualization
VIZ_MAX_CHILDREN=5

# Width of the value bar in ASCII visualization
VIZ_BAR_WIDTH=12

# ── Demo Script ───────────────────────────────────────────────────────────────

# Output directory for generated files
OUTPUTS_DIR=outputs

# Seed used by demo.py for algorithm RNG (GridWorld demo)
DEMO_SEED=7

# Seed used for the MaxTree environment in demo.py
DEMO_MAXTREE_SEED=123

# Simulations used by the single-search demos in demo.py
DEMO_N_SIM=150

# Trials used by the benchmark section of demo.py
DEMO_BENCH_TRIALS=15
